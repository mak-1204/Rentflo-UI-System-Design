# Rentflo Owner Web — Environment Variables
# Copy this file to .env.local and fill in values

# Internal backend service URL (server-side only — never exposed to browser)
BACKEND_API_URL=http://localhost:3000/api

# Public app URL (safe to expose to browser)
NEXT_PUBLIC_APP_URL=http://localhost:5174

# Portfolio web URL (used to build "View live site" link in sidebar)
NEXT_PUBLIC_PORTFOLIO_URL=http://localhost:5175
