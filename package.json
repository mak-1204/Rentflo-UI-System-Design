{
  "name": "stayflo-monorepo",
  "private": true,
  "version": "1.0.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npx concurrently -k -p \"[{name}]\" -n \"owner,portfolio,admin\" -c \"green,magenta,yellow\" \"npm run dev:owner-web\" \"npm run dev:portfolio-web\" \"npm run dev:admin-web\"",
    "build": "npm run build --workspaces --if-present",
    "dev:selector": "npm run dev -w apps/product-selector",
    "dev:owner-web": "npm run dev -w apps/owner-web",
    "dev:portfolio-web": "npm run dev -w apps/portfolio-web",
    "dev:tenant-mobile": "npm run dev -w apps/tenant-mobile",
    "dev:owner-mobile": "npm run dev -w apps/owner-mobile",
    "dev:admin-web": "npm run dev -w apps/admin-web",
    "dev:backend": "npm run dev -w apps/backend"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.1",
    "tailwindcss": "4.1.12",
    "typescript": "^5.2.2"
  },
  "dependencies": {
    "@supabase/ssr": "^0.10.3",
    "@supabase/supabase-js": "^2.107.0"
  }
}
